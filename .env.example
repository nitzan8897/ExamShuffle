# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-api-key-here

# Optional: override the Gemini model used for extraction
GEMINI_MODEL=gemini-2-flash

# Optional: persist jobs + output PDFs to MongoDB so they survive a server
# restart/redeploy (e.g. Railway OOM). Without it, jobs fall back to a local
# file + disk and are lost on restart. MONGODB_DB defaults to the URI's db.
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/examshuffle
# MONGODB_DB=examshuffle
